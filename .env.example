# ShellPilot environment — copy to .env and adjust.
# Values referenced from config.yml via ${ENV_VAR} expansion.

# Mongo
DATABASE_URI=mongodb://localhost:27017/shellpilot

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (random, long-lived)
JWT_SECRET=please-generate-with-openssl-rand-base64-48

# Bootstrap admin (created on first boot if no users exist)
BOOTSTRAP_ADMIN_EMAIL=admin@shellpilot.local
BOOTSTRAP_ADMIN_PASSWORD=changeme

# AES-256-GCM master key. MUST decode to 32 bytes.
# Generate with: openssl rand -base64 32
SECRETS_MASTER_KEY=
